[Unit]
Description=Panic Button Handler (GPIO17)
After=multi-user.target NetworkManager.service
Wants=NetworkManager.service

[Service]
Type=simple

ExecStart=/home/pizero/wireless-lab/services/panicButton/venv/bin/python /home/pizero/wireless-lab/services/panicButton/panicButton.py
WorkingDirectory=/home/pizero/wireless-lab/services/panicButton

# Restart If It Ever Crashes
Restart=always
RestartSec=1

# Needs Root For GPIO + Power + Systemctl
User=root

Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target

